{
  "expo": {
    "name": "Tiny Aura",
    "slug": "tiny-aura-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "tinyaura",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f2ebde"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "us.tinyaura.app",
      "buildNumber": "1",
      "infoPlist": {
        "CFBundleDisplayName": "Tiny Aura",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "us.tinyaura.app",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#f2ebde",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "eas": {
        "projectId": "2a928c33-7b14-4704-a2f5-7544d6da758a"
      },
      "router": {}
    },
    "owner": "smirnovrostyslav"
  }
}
