{
  "expo": {
    "name": "Kiss of Aroma",
    "slug": "tiny-aura-app",
    "version": "1.1.1",
    "orientation": "portrait",
    "scheme": [
      "kissofaroma",
      "shop.71650345091"
    ],
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f2ebde"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "us.tinyaura.app",
      "buildNumber": "9",
      "infoPlist": {
        "CFBundleDisplayName": "Kiss of Aroma",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "shop.kissofaroma.app",
      "versionCode": 8,
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "2a928c33-7b14-4704-a2f5-7544d6da758a"
      },
      "router": {}
    },
    "owner": "smirnovrostyslav"
  }
}
